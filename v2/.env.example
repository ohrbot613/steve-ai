# ─────────────────────────────────────────────────────────────────────────────
# Steve AI v2 — Environment Variables
# Copy this file to .env.local for local development (never commit .env.local)
# In Vercel, set these under Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────

# Your Supabase project URL — found in Settings → API
# Example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — safe to expose to the browser
# Found in Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — NEVER expose this to the browser
# Used only by server-side functions (xero-poll.js) to bypass RLS
# Found in Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Claude / Anthropic ────────────────────────────────────────────────────────

# Anthropic API key — used by extract.js to parse bank statement files
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Xero OAuth ───────────────────────────────────────────────────────────────

# Xero app credentials — used by xero-poll.js to refresh OAuth tokens
# Create a Xero app at: https://developer.xero.com/app/manage
# Scopes needed: openid profile email offline_access accounting.transactions accounting.contacts

XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret

# Xero OAuth redirect URI — must match what's registered in your Xero app
# Example: https://your-vercel-deployment.vercel.app/api/xero-callback
XERO_REDIRECT_URI=https://your-app.vercel.app/api/xero-callback

# ── App URL ───────────────────────────────────────────────────────────────────

# Public URL of the deployed app — used for OAuth redirects
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Analytics ────────────────────────────────────────────────────────────────

# PostHog analytics key — public/anon, safe for browser (REC-335)
# Leave blank to disable analytics (PostHog snippet will still load but won't fire events)
# Get from: app.posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key_here

# ── Vercel Cron Secret ────────────────────────────────────────────────────────

# Random secret used to authenticate Vercel's cron calls to /api/xero-poll
# Vercel automatically sets Authorization: Bearer <CRON_SECRET> on cron requests
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
