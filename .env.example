# OpenRouter API Configuration
OPEN_ROUTER=your_openrouter_api_key_here

# Google AI Configuration
AI_KEY=your_google_ai_key_here

# Xero API Configuration
XERO_CLIENT_ID=your_xero_client_id_here
XERO_CLIENT_SECRET=your_xero_client_secret_here
XERO_REDIRECT_URI=https://yourdomain.com/api/v1/auth/register-xero-callback

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_here

# Server Configuration
PORT=3001

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=yourapp
MONGO_USER=your_mongodb_username
MONGO_PASS=your_mongodb_password

# Sentry (optional - leave empty to disable)
# Backend: set SENTRY_DSN for server-side error capture and /api/v1/report-error.
# Frontend: in client/.env set VITE_SENTRY_DSN=<same or frontend DSN> for client error capture.
